# ======================================================================
# Autonomous PR Reviewer — environment configuration
# Copy this file to `.env` and fill in real values.
# ======================================================================

# ---- GitHub ----
# A GitHub token (classic or fine-grained) with `repo` + `pull_requests:write`.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Shared secret configured on the GitHub webhook (used to verify signatures).
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ---- LLM ----
# Option A — Anthropic (best quality; paid):
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-5
#
# Option B — Groq (free tier; open models). Uncomment these and comment out
# the three lines above:
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=llama-3.3-70b-versatile

# ---- Langfuse (observability) — optional, needed from Phase 8 ----
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Redis (dedup + cache) — optional, defaults to localhost ----
REDIS_URL=redis://localhost:6379/0

# ---- App ----
LOG_LEVEL=INFO
